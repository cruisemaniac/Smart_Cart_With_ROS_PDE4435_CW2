  <!-- DIFF DRIVE -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">

      <left_joint>FL_joint</left_joint>
      <left_joint>RL_joint</left_joint>

      <right_joint>FR_joint</right_joint>
      <right_joint>RR_joint</right_joint>

      <wheel_separation>0.44</wheel_separation>
      <wheel_radius>0.125</wheel_radius>

      <topic>/cmd_vel</topic>

    </plugin>
  </gazebo>
  
  <!-- Lidar -->
  <link name="lidar_link">
  <visual>
    <geometry>
      <cylinder radius="0.04" length="0.05"/>
    </geometry>
    <material name="grey">
      <color rgba="0.6 0.6 0.6 1"/>
    </material>
  </visual>

  <collision>
    <geometry>
      <cylinder radius="0.04" length="0.05"/>
    </geometry>
  </collision>

  <inertial>
    <mass value="0.17"/>
    <inertia ixx="0.0001" iyy="0.0001" izz="0.0001"
             ixy="0" ixz="0" iyz="0"/>
  </inertial>
</link>

<joint name="lidar_joint" type="fixed">
  <parent link="base_link"/>
  <child link="lidar_link"/>
  <origin xyz="0.5 0 0.3"/>
</joint>

<gazebo reference="lidar_link">
  <sensor name="lidar" type="gpu_lidar">
    <always_on>true</always_on>
    <update_rate>10</update_rate>
    <visualize>true</visualize>

    <topic>scan</topic>   <!-- NOTE: no "/" -->

    <lidar>
      <scan>
        <horizontal>
          <samples>360</samples>
          <min_angle>-3.14</min_angle>
          <max_angle>3.14</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.12</min>
        <max>12.0</max>
      </range>
    </lidar>
  </sensor>
</gazebo>

<!-- ultrasonic_left -->
<link name="ultrasonic_left">
  <visual>
    <geometry><box size="0.015 0.015 0.012"/></geometry>
  </visual>
</link>

<joint name="ultra_left_joint" type="fixed">
  <parent link="base_link"/>
  <child link="ultrasonic_left"/>
  <origin xyz="0.44 0.2 0.3"/>
</joint>

<gazebo reference="ultrasonic_left">
  <sensor name="ultra_left" type="gpu_lidar">
    <topic>/ultrasonic/left</topic>
    <update_rate>10</update_rate>
    <lidar>
      <scan>
        <horizontal>
          <samples>5</samples>
          <min_angle>-0.13</min_angle>
          <max_angle>0.13</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.02</min>
        <max>4.0</max>
      </range>
    </lidar>
  </sensor>
</gazebo>

