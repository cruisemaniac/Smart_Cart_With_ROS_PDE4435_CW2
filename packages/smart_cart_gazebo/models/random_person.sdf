<?xml version="1.0"?>
<!--
  random_person.sdf
  ─────────────────────────────────────────────────────────────────────────────
  Autonomous random-walking pedestrian for the supermarket simulation.
  Controlled entirely by random_person_node (ROS 2) — no teleop, no effect on
  the main person / cart system.

  Topics (all isolated under /random_person/ namespace):
    /random_person/cmd_vel   ← ROS → GZ  (velocity commands from node)
    /random_person/odom      → ROS        (odometry for node's collision check)
  TF:  odom → random_person  (via standard /tf bridge, same as main person)

  Visual: orange torso + skin head so the model is easy to distinguish from
          the main blue person in RViz/Gazebo.
-->
<sdf version="1.10">
<model name="random_person">

  <!-- ──────────────────────────────────────────────────────────────────────
       MAIN BODY LINK
       Single cylinder collision capsule centred at z=0.90 so it never
       touches the floor (drive wheels and casters take the weight).
  ────────────────────────────────────────────────────────────────────────── -->
  <link name="random_person">

    <inertial>
      <pose>0 0 0.90 0 0 0</pose>
      <mass>70.0</mass>
      <inertia>
        <ixx>10.0</ixx><iyy>10.0</iyy><izz>1.5</izz>
        <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
      </inertia>
    </inertial>

    <collision name="body_col">
      <pose>0 0 0.90 0 0 0</pose>
      <geometry>
        <cylinder><radius>0.22</radius><length>1.4</length></cylinder>
      </geometry>
    </collision>

    <!-- Torso (orange) -->
    <visual name="torso_vis">
      <pose>0 0 0.80 0 0 0</pose>
      <geometry><cylinder><radius>0.20</radius><length>0.52</length></cylinder></geometry>
      <material><ambient>0.85 0.40 0.05 1</ambient><diffuse>0.85 0.40 0.05 1</diffuse></material>
    </visual>

    <!-- Legs (dark brown) -->
    <visual name="left_leg_vis">
      <pose>0.05 0.10 0.22 0 0 0</pose>
      <geometry><cylinder><radius>0.07</radius><length>0.44</length></cylinder></geometry>
      <material><ambient>0.35 0.20 0.10 1</ambient><diffuse>0.35 0.20 0.10 1</diffuse></material>
    </visual>
    <visual name="right_leg_vis">
      <pose>0.05 -0.10 0.22 0 0 0</pose>
      <geometry><cylinder><radius>0.07</radius><length>0.44</length></cylinder></geometry>
      <material><ambient>0.35 0.20 0.10 1</ambient><diffuse>0.35 0.20 0.10 1</diffuse></material>
    </visual>

    <!-- Arms -->
    <visual name="left_arm_vis">
      <pose>0 0.28 0.82 0 0.3 0</pose>
      <geometry><cylinder><radius>0.055</radius><length>0.48</length></cylinder></geometry>
      <material><ambient>0.88 0.70 0.50 1</ambient><diffuse>0.88 0.70 0.50 1</diffuse></material>
    </visual>
    <visual name="right_arm_vis">
      <pose>0 -0.28 0.82 0 -0.3 0</pose>
      <geometry><cylinder><radius>0.055</radius><length>0.48</length></cylinder></geometry>
      <material><ambient>0.88 0.70 0.50 1</ambient><diffuse>0.88 0.70 0.50 1</diffuse></material>
    </visual>

    <!-- Head (skin) -->
    <visual name="head_vis">
      <pose>0 0 1.30 0 0 0</pose>
      <geometry><sphere><radius>0.14</radius></sphere></geometry>
      <material><ambient>0.88 0.70 0.50 1</ambient><diffuse>0.88 0.70 0.50 1</diffuse></material>
    </visual>

  </link>

  <!-- ──────────────────────────────────────────────────────────────────────
       DRIVE WHEELS
  ────────────────────────────────────────────────────────────────────────── -->
  <link name="left_wheel">
    <pose>0 0.25 0.10 1.5708 0 0</pose>
    <inertial>
      <mass>1.0</mass>
      <inertia><ixx>0.0025</ixx><iyy>0.0025</iyy><izz>0.005</izz>
               <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
    </inertial>
    <collision name="col">
      <geometry><cylinder><radius>0.10</radius><length>0.04</length></cylinder></geometry>
      <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
    </collision>
    <visual name="vis">
      <geometry><cylinder><radius>0.10</radius><length>0.04</length></cylinder></geometry>
      <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
    </visual>
  </link>

  <link name="right_wheel">
    <pose>0 -0.25 0.10 1.5708 0 0</pose>
    <inertial>
      <mass>1.0</mass>
      <inertia><ixx>0.0025</ixx><iyy>0.0025</iyy><izz>0.005</izz>
               <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
    </inertial>
    <collision name="col">
      <geometry><cylinder><radius>0.10</radius><length>0.04</length></cylinder></geometry>
      <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
    </collision>
    <visual name="vis">
      <geometry><cylinder><radius>0.10</radius><length>0.04</length></cylinder></geometry>
      <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
    </visual>
  </link>

  <!-- ──────────────────────────────────────────────────────────────────────
       CASTERS  (spheres, near-zero friction so they slide freely)
  ────────────────────────────────────────────────────────────────────────── -->
  <link name="caster_front">
    <pose>0.20 0 0.10 0 0 0</pose>
    <inertial><mass>0.5</mass>
      <inertia><ixx>0.002</ixx><iyy>0.002</iyy><izz>0.002</izz>
               <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
    </inertial>
    <collision name="col">
      <geometry><sphere><radius>0.10</radius></sphere></geometry>
      <surface><friction><ode><mu>0.01</mu><mu2>0.01</mu2></ode></friction></surface>
    </collision>
  </link>

  <link name="caster_rear">
    <pose>-0.20 0 0.10 0 0 0</pose>
    <inertial><mass>0.5</mass>
      <inertia><ixx>0.002</ixx><iyy>0.002</iyy><izz>0.002</izz>
               <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
    </inertial>
    <collision name="col">
      <geometry><sphere><radius>0.10</radius></sphere></geometry>
      <surface><friction><ode><mu>0.01</mu><mu2>0.01</mu2></ode></friction></surface>
    </collision>
  </link>

  <!-- ──────────────────────────────────────────────────────────────────────
       JOINTS
  ────────────────────────────────────────────────────────────────────────── -->
  <joint name="left_wheel_joint" type="revolute">
    <parent>random_person</parent><child>left_wheel</child>
    <axis>
      <xyz>0 0 -1</xyz>
      <limit><lower>-1e16</lower><upper>1e16</upper></limit>
      <dynamics><damping>0.01</damping><friction>0.01</friction></dynamics>
    </axis>
  </joint>

  <joint name="right_wheel_joint" type="revolute">
    <parent>random_person</parent><child>right_wheel</child>
    <axis>
      <xyz>0 0 -1</xyz>
      <limit><lower>-1e16</lower><upper>1e16</upper></limit>
      <dynamics><damping>0.01</damping><friction>0.01</friction></dynamics>
    </axis>
  </joint>

  <joint name="caster_front_joint" type="fixed">
    <parent>random_person</parent><child>caster_front</child>
  </joint>

  <joint name="caster_rear_joint" type="fixed">
    <parent>random_person</parent><child>caster_rear</child>
  </joint>

  <!-- ──────────────────────────────────────────────────────────────────────
       PLUGINS
  ────────────────────────────────────────────────────────────────────────── -->
  <plugin filename="gz-sim-diff-drive-system"
          name="gz::sim::systems::DiffDrive">
    <left_joint>left_wheel_joint</left_joint>
    <right_joint>right_wheel_joint</right_joint>
    <wheel_separation>0.50</wheel_separation>
    <wheel_radius>0.10</wheel_radius>
    <max_linear_velocity>1.0</max_linear_velocity>
    <max_angular_velocity>2.0</max_angular_velocity>
    <max_linear_acceleration>1.5</max_linear_acceleration>
    <max_angular_acceleration>5.0</max_angular_acceleration>
    <odom_publish_frequency>10</odom_publish_frequency>
    <topic>random_person/cmd_vel</topic>
    <odom_topic>random_person/odom</odom_topic>
    <frame_id>odom</frame_id>
    <child_frame_id>random_person</child_frame_id>
  </plugin>

  <plugin filename="gz-sim-joint-state-publisher-system"
          name="gz::sim::systems::JointStatePublisher">
    <topic>random_person/joint_states</topic>
  </plugin>

</model>
</sdf>
