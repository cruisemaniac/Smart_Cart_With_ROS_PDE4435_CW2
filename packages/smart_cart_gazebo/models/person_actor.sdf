<?xml version="1.0" ?>
<!--
  person_actor.sdf  –  Keyboard-controlled person model
  ─────────────────────────────────────────────────────────────────────────────
  Realistic human shape:
    - Legs (2 cylinders)
    - Torso (wider cylinder)
    - Arms (2 thin cylinders, angled outward)
    - Head (sphere)
    - UWB remote tag (glowing cyan box held in hand)
    - UWB signal rings (concentric transparent spheres)

  Physics base: DiffDrive on two hidden wheels + 2 casters
  Spawned at z=0.12 from launch file (settles to ground)
  Controlled via /person/cmd_vel from teleop_person_node.py
-->
<sdf version="1.10">
  <model name="person">

    <self_collide>false</self_collide>
    <pose>0.0 0.0 0.0 0 0 0</pose>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- MAIN BODY LINK  –  contains all visual geometry                  -->
    <!-- Origin at ground level z=0                                       -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <link name="base_link">

      <inertial>
        <pose>0 0 0.90 0 0 0</pose>
        <mass>70.0</mass>
        <inertia>
          <ixx>10.0</ixx><iyy>10.0</iyy><izz>1.5</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>

      <!-- ── Collision (single capsule for physics) ── -->
      <collision name="body_col">
        <pose>0 0 0.90 0 0 0</pose>
        <geometry>
          <cylinder><radius>0.22</radius><length>1.4</length></cylinder>
        </geometry>
      </collision>

      <!-- ══════════════════════════════════════════ -->
      <!-- LEGS                                       -->
      <!-- ══════════════════════════════════════════ -->

      <!-- Left leg -->
      <visual name="left_leg">
        <pose>0.05 0.10 0.22 0 0 0</pose>
        <geometry>
          <cylinder><radius>0.07</radius><length>0.44</length></cylinder>
        </geometry>
        <material>
          <ambient>0.25 0.25 0.70 1</ambient>
          <diffuse>0.25 0.25 0.70 1</diffuse>
        </material>
      </visual>

      <!-- Right leg -->
      <visual name="right_leg">
        <pose>0.05 -0.10 0.22 0 0 0</pose>
        <geometry>
          <cylinder><radius>0.07</radius><length>0.44</length></cylinder>
        </geometry>
        <material>
          <ambient>0.25 0.25 0.70 1</ambient>
          <diffuse>0.25 0.25 0.70 1</diffuse>
        </material>
      </visual>

      <!-- Left shoe -->
      <visual name="left_shoe">
        <pose>0.07 0.10 0.04 0 0 0</pose>
        <geometry>
          <box><size>0.20 0.09 0.05</size></box>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>

      <!-- Right shoe -->
      <visual name="right_shoe">
        <pose>0.07 -0.10 0.04 0 0 0</pose>
        <geometry>
          <box><size>0.20 0.09 0.05</size></box>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>

      <!-- ══════════════════════════════════════════ -->
      <!-- TORSO                                      -->
      <!-- ══════════════════════════════════════════ -->
      <visual name="torso">
        <pose>0 0 0.80 0 0 0</pose>
        <geometry>
          <cylinder><radius>0.20</radius><length>0.52</length></cylinder>
        </geometry>
        <material>
          <ambient>0.20 0.45 0.80 1</ambient>
          <diffuse>0.20 0.45 0.80 1</diffuse>
          <specular>0.2 0.2 0.2 1</specular>
        </material>
      </visual>

      <!-- ══════════════════════════════════════════ -->
      <!-- ARMS                                       -->
      <!-- ══════════════════════════════════════════ -->

      <!-- Left arm -->
      <visual name="left_arm">
        <pose>0 0.28 0.82 0 0.3 0</pose>
        <geometry>
          <cylinder><radius>0.055</radius><length>0.48</length></cylinder>
        </geometry>
        <material>
          <ambient>0.88 0.70 0.50 1</ambient>
          <diffuse>0.88 0.70 0.50 1</diffuse>
        </material>
      </visual>

      <!-- Right arm – holds the UWB remote -->
      <visual name="right_arm">
        <pose>0 -0.28 0.82 0 -0.3 0</pose>
        <geometry>
          <cylinder><radius>0.055</radius><length>0.48</length></cylinder>
        </geometry>
        <material>
          <ambient>0.88 0.70 0.50 1</ambient>
          <diffuse>0.88 0.70 0.50 1</diffuse>
        </material>
      </visual>

      <!-- ══════════════════════════════════════════ -->
      <!-- NECK                                       -->
      <!-- ══════════════════════════════════════════ -->
      <visual name="neck">
        <pose>0 0 1.10 0 0 0</pose>
        <geometry>
          <cylinder><radius>0.065</radius><length>0.10</length></cylinder>
        </geometry>
        <material>
          <ambient>0.88 0.70 0.50 1</ambient>
          <diffuse>0.88 0.70 0.50 1</diffuse>
        </material>
      </visual>

      <!-- ══════════════════════════════════════════ -->
      <!-- HEAD                                       -->
      <!-- ══════════════════════════════════════════ -->
      <visual name="head">
        <pose>0 0 1.30 0 0 0</pose>
        <geometry>
          <sphere><radius>0.14</radius></sphere>
        </geometry>
        <material>
          <ambient>0.88 0.70 0.50 1</ambient>
          <diffuse>0.88 0.70 0.50 1</diffuse>
        </material>
      </visual>

      <!-- Hair -->
      <visual name="hair">
        <pose>0 0 1.42 0 0 0</pose>
        <geometry>
          <sphere><radius>0.145</radius></sphere>
        </geometry>
        <material>
          <ambient>0.20 0.12 0.05 1</ambient>
          <diffuse>0.20 0.12 0.05 1</diffuse>
        </material>
      </visual>

      <!-- ══════════════════════════════════════════ -->
      <!-- UWB REMOTE TAG                             -->
      <!-- Held in right hand at waist height         -->
      <!-- Glowing cyan = active UWB signal           -->
      <!-- ══════════════════════════════════════════ -->

      <!-- Remote housing -->
      <visual name="uwb_remote_body">
        <pose>0.15 -0.32 0.68 0 0 0</pose>
        <geometry>
          <box><size>0.10 0.05 0.16</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>

      <!-- Remote screen – glowing cyan -->
      <visual name="uwb_remote_screen">
        <pose>0.20 -0.32 0.72 0 0 0</pose>
        <geometry>
          <box><size>0.01 0.04 0.08</size></box>
        </geometry>
        <material>
          <ambient>0.0  1.0  1.0  1.0</ambient>
          <diffuse>0.0  1.0  1.0  1.0</diffuse>
          <emissive>0.0 0.9  1.0  1.0</emissive>
        </material>
      </visual>

      <!-- Button 1 (STOP) – red -->
      <visual name="btn_stop">
        <pose>0.20 -0.30 0.65 0 0 0</pose>
        <geometry><sphere><radius>0.012</radius></sphere></geometry>
        <material>
          <ambient>1.0 0.0 0.0 1</ambient>
          <diffuse>1.0 0.0 0.0 1</diffuse>
          <emissive>0.8 0.0 0.0 1</emissive>
        </material>
      </visual>

      <!-- Button 2 (FOLLOW) – green -->
      <visual name="btn_follow">
        <pose>0.20 -0.32 0.65 0 0 0</pose>
        <geometry><sphere><radius>0.012</radius></sphere></geometry>
        <material>
          <ambient>0.0 1.0 0.0 1</ambient>
          <diffuse>0.0 1.0 0.0 1</diffuse>
          <emissive>0.0 0.8 0.0 1</emissive>
        </material>
      </visual>

      <!-- Button 3 (IDLE) – yellow -->
      <visual name="btn_idle">
        <pose>0.20 -0.34 0.65 0 0 0</pose>
        <geometry><sphere><radius>0.012</radius></sphere></geometry>
        <material>
          <ambient>1.0 1.0 0.0 1</ambient>
          <diffuse>1.0 1.0 0.0 1</diffuse>
          <emissive>0.8 0.8 0.0 1</emissive>
        </material>
      </visual>

      <!-- UWB signal inner glow -->
      <visual name="uwb_signal_inner">
        <pose>0.15 -0.32 0.70 0 0 0</pose>
        <geometry><sphere><radius>0.12</radius></sphere></geometry>
        <material>
          <ambient>0.0  1.0  1.0  0.4</ambient>
          <diffuse>0.0  1.0  1.0  0.4</diffuse>
          <emissive>0.0 0.9  1.0  1.0</emissive>
        </material>
        <transparency>0.60</transparency>
      </visual>

      <!-- UWB signal outer glow -->
      <visual name="uwb_signal_outer">
        <pose>0.15 -0.32 0.70 0 0 0</pose>
        <geometry><sphere><radius>0.22</radius></sphere></geometry>
        <material>
          <ambient>0.0  0.85 1.0  0.15</ambient>
          <diffuse>0.0  0.85 1.0  0.15</diffuse>
          <emissive>0.0 0.75 1.0  1.0</emissive>
        </material>
        <transparency>0.85</transparency>
      </visual>

    </link>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- DRIVE WHEELS  –  hidden under body, same colour as floor         -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <link name="left_wheel">
      <pose>0 0.25 0.10 1.5708 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.005</ixx><iyy>0.005</iyy><izz>0.005</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="col">
        <geometry>
          <cylinder><radius>0.10</radius><length>0.04</length></cylinder>
        </geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
      <visual name="vis">
        <geometry>
          <cylinder><radius>0.10</radius><length>0.04</length></cylinder>
        </geometry>
        <material>
          <ambient>0.82 0.82 0.78 1</ambient>
          <diffuse>0.82 0.82 0.78 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="right_wheel">
      <pose>0 -0.25 0.10 1.5708 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.005</ixx><iyy>0.005</iyy><izz>0.005</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="col">
        <geometry>
          <cylinder><radius>0.10</radius><length>0.04</length></cylinder>
        </geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
      <visual name="vis">
        <geometry>
          <cylinder><radius>0.10</radius><length>0.04</length></cylinder>
        </geometry>
        <material>
          <ambient>0.82 0.82 0.78 1</ambient>
          <diffuse>0.82 0.82 0.78 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- CASTERS                                                           -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <link name="caster_rear">
      <pose>-0.20 0 0.10 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.002</ixx><iyy>0.002</iyy><izz>0.002</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="col">
        <geometry><sphere><radius>0.10</radius></sphere></geometry>
        <surface>
          <friction><ode><mu>0.01</mu><mu2>0.01</mu2></ode></friction>
        </surface>
      </collision>
      <visual name="vis">
        <geometry><sphere><radius>0.10</radius></sphere></geometry>
        <material>
          <ambient>0.82 0.82 0.78 1</ambient>
          <diffuse>0.82 0.82 0.78 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="caster_front">
      <pose>0.20 0 0.10 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.002</ixx><iyy>0.002</iyy><izz>0.002</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="col">
        <geometry><sphere><radius>0.10</radius></sphere></geometry>
        <surface>
          <friction><ode><mu>0.01</mu><mu2>0.01</mu2></ode></friction>
        </surface>
      </collision>
      <visual name="vis">
        <geometry><sphere><radius>0.10</radius></sphere></geometry>
        <material>
          <ambient>0.82 0.82 0.78 1</ambient>
          <diffuse>0.82 0.82 0.78 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- JOINTS                                                            -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.01</damping><friction>0.01</friction></dynamics>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.01</damping><friction>0.01</friction></dynamics>
      </axis>
    </joint>

    <joint name="caster_rear_joint" type="fixed">
      <parent>base_link</parent>
      <child>caster_rear</child>
    </joint>

    <joint name="caster_front_joint" type="fixed">
      <parent>base_link</parent>
      <child>caster_front</child>
    </joint>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- PLUGINS                                                           -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.50</wheel_separation>
      <wheel_radius>0.10</wheel_radius>
      <max_linear_velocity>1.5</max_linear_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>
      <max_linear_acceleration>2.0</max_linear_acceleration>
      <odom_publish_frequency>20</odom_publish_frequency>
      <topic>person/cmd_vel</topic>
      <odom_topic>person/odom</odom_topic>
      <tf_topic>person/tf</tf_topic>
      <frame_id>person_odom</frame_id>
      <child_frame_id>person</child_frame_id>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>person/joint_states</topic>
    </plugin>

  </model>
</sdf>
