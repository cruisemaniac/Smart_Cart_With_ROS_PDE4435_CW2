  </link>
  <joint name="shelf_C_right_joint" type="fixed"><parent link="world"/><child link="shelf_C_right"/><origin xyz="13.5 -1.5 0.9" rpy="0 0 0"/></joint>

  <link name="shelf_C_right_b1"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_C_right_b1_jnt" type="fixed"><parent link="world"/><child link="shelf_C_right_b1"/><origin xyz="13.5 -1.5 0.40" rpy="0 0 0"/></joint>
  <link name="shelf_C_right_b2"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_C_right_b2_jnt" type="fixed"><parent link="world"/><child link="shelf_C_right_b2"/><origin xyz="13.5 -1.5 0.85" rpy="0 0 0"/></joint>
  <link name="shelf_C_right_b3"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_C_right_b3_jnt" type="fixed"><parent link="world"/><child link="shelf_C_right_b3"/><origin xyz="13.5 -1.5 1.30" rpy="0 0 0"/></joint>

