<?xml version="1.0" ?>
<!--
  supermarket.urdf  -  Expanded realistic supermarket environment
  Converted and enlarged from supermarket.sdf

  Layout overview (top-down, X = forward/depth, Y = lateral):
    ┌──────────────────────────────────────────────────────┐  y= 6.5 (left wall)
    │  [Shelf A1]  [Shelf A2]  [Shelf A3]  [Shelf A4]     │
    │                                                       │  ← left aisle gap
    │                    MAIN AISLE                         │  y= 0
    │                                                       │  ← right aisle gap
    │  [Shelf B1]  [Shelf B2]  [Shelf B3]  [Shelf B4]     │
    └──────────────────────────────────────────────────────┘  y=-6.5 (right wall)

  Aisle between shelf rows: exactly preserved from original
    Left shelf face:  y = 1.5 - 0.225 = 1.275
    Right shelf face: y = -1.5 + 0.225 = -1.275
    Clear gap = 2.55 m  (same as original)

  Person/actor spawned separately - not included here.
-->
<robot name="supermarket">

  <!-- ═══════════════════════════════════════════════════════════════════════
       WORLD LINK  (static anchor)
  ═══════════════════════════════════════════════════════════════════════ -->
  <link name="world"/>

  <!-- ═══════════════════════════════════════════════════════════════════════
       GROUND PLANE
  ═══════════════════════════════════════════════════════════════════════ -->
  <link name="ground_plane">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="32 14 0.02"/>
      </geometry>
      <material name="floor_tile">
        <!-- Light grey / cream vinyl tile -->
        <color rgba="0.88 0.87 0.84 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="32 14 0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="100000"/>
      <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/>
    </inertial>
  </link>

  <joint name="ground_joint" type="fixed">
    <parent link="world"/>
    <child link="ground_plane"/>
    <!-- Centre at x=14 = midpoint of [-2, 30]; y=0; just below z=0 -->
    <origin xyz="14.0 0 -0.01" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════════════
       WALLS
       Building footprint: X ∈ [-1, 29]  Y ∈ [-7, 7]  Z ∈ [0, 3.5]
  ═══════════════════════════════════════════════════════════════════════ -->

  <!-- Left wall (y = +7) -->
  <link name="left_wall">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="30 0.2 3.5"/></geometry>
      <material name="wall_mat"><color rgba="0.90 0.90 0.88 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="30 0.2 3.5"/></geometry>
    </collision>
    <inertial><mass value="10000"/><inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/></inertial>
  </link>
  <joint name="left_wall_joint" type="fixed">
    <parent link="world"/>
    <child link="left_wall"/>
    <origin xyz="14 7.0 1.75" rpy="0 0 0"/>
  </joint>

  <!-- Right wall (y = -7) -->
  <link name="right_wall">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="30 0.2 3.5"/></geometry>
      <material name="wall_mat"><color rgba="0.90 0.90 0.88 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="30 0.2 3.5"/></geometry>
    </collision>
    <inertial><mass value="10000"/><inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/></inertial>
  </link>
  <joint name="right_wall_joint" type="fixed">
    <parent link="world"/>
    <child link="right_wall"/>
    <origin xyz="14 -7.0 1.75" rpy="0 0 0"/>
  </joint>

  <!-- Back wall (x = 29) -->
  <link name="back_wall">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.2 14.4 3.5"/></geometry>
      <material name="wall_mat"><color rgba="0.90 0.90 0.88 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.2 14.4 3.5"/></geometry>
    </collision>
    <inertial><mass value="10000"/><inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/></inertial>
  </link>
  <joint name="back_wall_joint" type="fixed">
    <parent link="world"/>
    <child link="back_wall"/>
    <origin xyz="29.0 0 1.75" rpy="0 0 0"/>
  </joint>

  <!-- Front wall (x = -1) - left portion (entrance gap in middle) -->
  <link name="front_wall_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.2 5.2 3.5"/></geometry>
      <material name="wall_mat"><color rgba="0.90 0.90 0.88 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.2 5.2 3.5"/></geometry>
    </collision>
    <inertial><mass value="10000"/><inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/></inertial>
  </link>
  <joint name="front_wall_left_joint" type="fixed">
    <parent link="world"/>
    <child link="front_wall_left"/>
    <origin xyz="-1.0 4.4 1.75" rpy="0 0 0"/>
  </joint>

  <link name="front_wall_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.2 5.2 3.5"/></geometry>
      <material name="wall_mat"><color rgba="0.90 0.90 0.88 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.2 5.2 3.5"/></geometry>
    </collision>
    <inertial><mass value="10000"/><inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/></inertial>
  </link>
  <joint name="front_wall_right_joint" type="fixed">
    <parent link="world"/>
    <child link="front_wall_right"/>
    <origin xyz="-1.0 -4.4 1.75" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SHELF MACRO LAYOUT

       Shelf unit dimensions (same depth as original, just taller + longer):
         size: 4.0 (length along X) × 0.45 (depth Y) × 1.8 (height Z)

       Left row:  y = +1.5   (face at y=1.275, same as original)
       Right row: y = -1.5   (face at y=-1.275, same as original)

       4 shelf units per row, spaced 5.0 m apart (with 1.0 m cross-aisle gap)
       Rows: A (x≈3.5), B (x≈8.5), C (x≈13.5), D (x≈18.5), E (x≈23.5)

       Each shelf unit has 3 visible shelf boards inside it.
  ═══════════════════════════════════════════════════════════════════════ -->

  <!-- ────────────────────────────────────────────────────────────────────
       ROW A  (x = 3.5)  — Bakery / Bread
  ──────────────────────────────────────────────────────────────────── -->

  <!-- A-Left shelf body -->
  <link name="shelf_A_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="4.0 0.45 1.8"/></geometry>
      <material name="shelf_wood"><color rgba="0.60 0.42 0.20 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="4.0 0.45 1.8"/></geometry>
    </collision>
    <inertial><mass value="200"/><inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/></inertial>
  </link>
  <joint name="shelf_A_left_joint" type="fixed">
    <parent link="world"/>
    <child link="shelf_A_left"/>
    <origin xyz="3.5 1.5 0.9" rpy="0 0 0"/>
  </joint>

  <!-- A-Left shelf boards (3 levels) -->
  <link name="shelf_A_left_b1"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_A_left_b1_jnt" type="fixed"><parent link="world"/><child link="shelf_A_left_b1"/><origin xyz="3.5 1.5 0.40" rpy="0 0 0"/></joint>

  <link name="shelf_A_left_b2"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_A_left_b2_jnt" type="fixed"><parent link="world"/><child link="shelf_A_left_b2"/><origin xyz="3.5 1.5 0.85" rpy="0 0 0"/></joint>

  <link name="shelf_A_left_b3"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_A_left_b3_jnt" type="fixed"><parent link="world"/><child link="shelf_A_left_b3"/><origin xyz="3.5 1.5 1.30" rpy="0 0 0"/></joint>

  <!-- A-Right shelf body -->
  <link name="shelf_A_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="4.0 0.45 1.8"/></geometry>
      <material name="shelf_wood"><color rgba="0.60 0.42 0.20 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="4.0 0.45 1.8"/></geometry>
    </collision>
    <inertial><mass value="200"/><inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/></inertial>
  </link>
  <joint name="shelf_A_right_joint" type="fixed">
    <parent link="world"/>
    <child link="shelf_A_right"/>
    <origin xyz="3.5 -1.5 0.9" rpy="0 0 0"/>
  </joint>

  <link name="shelf_A_right_b1"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_A_right_b1_jnt" type="fixed"><parent link="world"/><child link="shelf_A_right_b1"/><origin xyz="3.5 -1.5 0.40" rpy="0 0 0"/></joint>

  <link name="shelf_A_right_b2"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_A_right_b2_jnt" type="fixed"><parent link="world"/><child link="shelf_A_right_b2"/><origin xyz="3.5 -1.5 0.85" rpy="0 0 0"/></joint>

  <link name="shelf_A_right_b3"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_A_right_b3_jnt" type="fixed"><parent link="world"/><child link="shelf_A_right_b3"/><origin xyz="3.5 -1.5 1.30" rpy="0 0 0"/></joint>

  <!-- ────────────────────────────────────────────────────────────────────
       ROW B  (x = 8.5)  — Canned Goods / Dry Foods
  ──────────────────────────────────────────────────────────────────── -->

  <link name="shelf_B_left">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.45 1.8"/></geometry><material name="shelf_wood"><color rgba="0.60 0.42 0.20 1"/></material></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.45 1.8"/></geometry></collision>
    <inertial><mass value="200"/><inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/></inertial>
  </link>
  <joint name="shelf_B_left_joint" type="fixed"><parent link="world"/><child link="shelf_B_left"/><origin xyz="8.5 1.5 0.9" rpy="0 0 0"/></joint>

  <link name="shelf_B_left_b1"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_B_left_b1_jnt" type="fixed"><parent link="world"/><child link="shelf_B_left_b1"/><origin xyz="8.5 1.5 0.40" rpy="0 0 0"/></joint>
  <link name="shelf_B_left_b2"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_B_left_b2_jnt" type="fixed"><parent link="world"/><child link="shelf_B_left_b2"/><origin xyz="8.5 1.5 0.85" rpy="0 0 0"/></joint>
  <link name="shelf_B_left_b3"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_B_left_b3_jnt" type="fixed"><parent link="world"/><child link="shelf_B_left_b3"/><origin xyz="8.5 1.5 1.30" rpy="0 0 0"/></joint>

  <link name="shelf_B_right">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.45 1.8"/></geometry><material name="shelf_wood"><color rgba="0.60 0.42 0.20 1"/></material></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.45 1.8"/></geometry></collision>
    <inertial><mass value="200"/><inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/></inertial>
  </link>
  <joint name="shelf_B_right_joint" type="fixed"><parent link="world"/><child link="shelf_B_right"/><origin xyz="8.5 -1.5 0.9" rpy="0 0 0"/></joint>

  <link name="shelf_B_right_b1"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_B_right_b1_jnt" type="fixed"><parent link="world"/><child link="shelf_B_right_b1"/><origin xyz="8.5 -1.5 0.40" rpy="0 0 0"/></joint>
  <link name="shelf_B_right_b2"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_B_right_b2_jnt" type="fixed"><parent link="world"/><child link="shelf_B_right_b2"/><origin xyz="8.5 -1.5 0.85" rpy="0 0 0"/></joint>
  <link name="shelf_B_right_b3"><visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.46 0.03"/></geometry><material name="shelf_board"><color rgba="0.75 0.55 0.28 1"/></material></visual></link>
  <joint name="shelf_B_right_b3_jnt" type="fixed"><parent link="world"/><child link="shelf_B_right_b3"/><origin xyz="8.5 -1.5 1.30" rpy="0 0 0"/></joint>

  <!-- ────────────────────────────────────────────────────────────────────
       ROW C  (x = 13.5)  — Beverages / Juices
  ──────────────────────────────────────────────────────────────────── -->

  <link name="shelf_C_left">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.45 1.8"/></geometry><material name="shelf_wood"><color rgba="0.60 0.42 0.20 1"/></material></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="4.0 0.45 1.8"/></geometry></collision>
